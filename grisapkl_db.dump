--
-- Table structure for table `pkl_assessment_scores`
--

DROP TABLE IF EXISTS `pkl_assessment_scores`;
/*!40101 SET @saved_cs_client     = @@character_set_client */;
/*!50503 SET character_set_client = utf8mb4 */;
CREATE TABLE `pkl_assessment_scores` (
  `id` bigint unsigned NOT NULL AUTO_INCREMENT,
  `pkl_assessment_id` bigint unsigned NOT NULL,
  `assessment_indicator_id` bigint unsigned NOT NULL,
  `score` int NOT NULL,
  `created_at` timestamp NULL DEFAULT NULL,
  `updated_at` timestamp NULL DEFAULT NULL,
  PRIMARY KEY (`id`),
  KEY `pkl_assessment_scores_pkl_assessment_id_foreign` (`pkl_assessment_id`),
  KEY `pkl_assessment_scores_assessment_indicator_id_foreign` (`assessment_indicator_id`),
  CONSTRAINT `pkl_assessment_scores_assessment_indicator_id_foreign` FOREIGN KEY (`assessment_indicator_id`) REFERENCES `assessment_indicators` (`id`) ON DELETE CASCADE,
  CONSTRAINT `pkl_assessment_scores_pkl_assessment_id_foreign` FOREIGN KEY (`pkl_assessment_id`) REFERENCES `pkl_assessments` (`id`) ON DELETE CASCADE
) ENGINE=InnoDB AUTO_INCREMENT=63 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci;
/*!40101 SET character_set_client = @saved_cs_client */;

